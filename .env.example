# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ghsentinel
DATABASE_POOL_SIZE=20

# Authentication
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRY=7d

# Payment Processing (Stripe)
NEXT_PUBLIC_STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=ghsentinel-data

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@ghsentinel.com

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Feature Flags
ENABLE_PREMIUM_FEATURES=true
ENABLE_API_SANDBOX=true
ENABLE_BETA_FEATURES=false

# Government Integration
SENASA_API_KEY=your_senasa_key
COFEPRIS_API_KEY=your_cofepris_key
ICA_API_KEY=your_ica_key
